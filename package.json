{
  "name": "opencode-smart-router",
  "version": "1.4.2",
  "description": "OpenCode plugin that routes tasks to tiered subagents (fast/medium/heavy) based on complexity",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "build": "npm run build:tiers && npx tsc --project tsconfig.build.json && pnpm exec -- rolldown --config rolldown.config.js build",
    "build:tiers": "node --experimental-strip-types scripts/build-tiers-config.ts",
    "prebuild": "node --experimental-strip-types scripts/build-tiers-config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "smoke": "cross-env RUN_OC_SMOKE=1 vitest run --config vitest.smoke.config.ts test/smoke",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "format:check": "biome format"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MetalbolicX/opencode-smart-router.git"
  },
  "homepage": "https://github.com/MetalbolicX/opencode-smart-router",
  "bugs": {
    "url": "https://github.com/MetalbolicX/opencode-smart-router/issues"
  },
  "author": {
    "name": "Marco Jardim",
    "url": "https://github.com/marco-jardim"
  },
  "keywords": [
    "opencode",
    "claude-code",
    "plugin",
    "model-routing",
    "subagents",
    "delegation",
    "multi-model",
    "orchestration"
  ],
  "bin": {
    "osr": "./dist/cli.mjs"
  },
  "files": [
    "src/",
    "dist/",
    "tiers.json",
    "LICENSE",
    "README.md"
  ],
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "@vitest/coverage-v8": "^4.1.9",
    "cross-env": "^10.1.0",
    "rolldown": "^1.1.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
